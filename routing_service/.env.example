# Google AI Studio (get API key: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# optional: override default (free-tier friendly)
GEMINI_MODEL=gemini-2.0-flash

# --- Optional: Twilio outbound confirmation calls ---
# Public https base URL Twilio can reach (ngrok, Cloudflare Tunnel, deployed host). No trailing slash.
PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.app
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio phone number in E.164
TWILIO_FROM_NUMBER=
